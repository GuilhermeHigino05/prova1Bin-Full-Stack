

<div>
    <h1>Cadastro de Jogadores </h1>
    <form>
        <label for="name">Nome:</label>
        <input type="text" name="name" id="nome" required>
        <label for="numero">Numero: </label>
        <input type="number" name="numero" id="numero" required>
        <label for="posicao">Posição: </label>
        <select name="posicao" id="posicao">
            <% for (let i = 0; i < posicoes.length; i++) { %>
                <option value="<%= posicoes[i].pos_nome %>">
                    <%= posicoes[i].pos_nome %>
                </option>
            <% } %>
        </select>
        <label for="selecao">Seleção:</label>
        <input type="text" name="selecao" id="selecao">

        <button id="btn-cadastro">Cadastrar Jogador</button>
    </form>
</div>

<script src="../js/jogadores/cadastro.js"></script>